# Скопируй этот файл в .env и заполни реальными значениями
# Файл .env НЕ загружается в Git

# Bitrix24 — URL вебхука для приёма заявок с формы
BITRIX24_WEBHOOK_URL=https://ваш-портал.bitrix24.ru/rest/1/ключ/

# Bitrix24 — ID виджета чата Open Lines
BITRIX24_CHAT_WIDGET_ID=

# Яндекс.Метрика — номер счётчика
YANDEX_METRIKA_ID=

# Google Analytics 4 — Measurement ID (опционально)
GA4_MEASUREMENT_ID=
